# --- Microsoft Foundry ---
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_FOUNDRY_MODEL=gpt-5.2

# Use "chat" for Agent(client=FoundryChatClient(...)).
# Use "hosted" for FoundryAgent(...), backed by a service-managed Foundry agent.
FOUNDRY_AGENT_MODE=chat
AZURE_FOUNDRY_AGENT_NAME=
AZURE_FOUNDRY_AGENT_VERSION=

# Uses AzureCliCredential. Run `az login` before this example.

# --- Sigil generation export ---
SIGIL_PROTOCOL=http
SIGIL_ENDPOINT=https://sigil-prod-<region>.grafana.net
SIGIL_AUTH_MODE=basic
SIGIL_AUTH_TENANT_ID=
SIGIL_AUTH_TOKEN=

# --- OTel traces + metrics ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://<your-otlp-gateway-url>
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(otlp_instance_id:cloud_api_token)>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRIC_EXPORT_INTERVAL_MILLIS=1000
OTEL_SERVICE_NAME=sigil-foundry-agent-framework-example

SIGIL_CONVERSATION_ID=sigil-foundry-agent-framework-demo
SIGIL_AGENT_VERSION=dev
