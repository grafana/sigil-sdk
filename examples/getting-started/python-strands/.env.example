# Local Sigil defaults. Override if your local Sigil uses a different ingest endpoint.
SIGIL_EXPORT_PROTOCOL=grpc
SIGIL_ENDPOINT=localhost:4317
SIGIL_CONVERSATION_ID=local-sigil-strands-demo

# OTel metrics export through local Alloy in the Sigil dev stack.
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_METRIC_EXPORT_INTERVAL_MILLIS=1000
OTEL_SERVICE_NAME=sigil-strands-example

# The example uses Strands' OpenAI model provider by default.
STRANDS_MODEL_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# To use Strands' default Bedrock model instead:
# STRANDS_MODEL_PROVIDER=bedrock
# AWS_PROFILE=
# AWS_REGION=us-west-2
