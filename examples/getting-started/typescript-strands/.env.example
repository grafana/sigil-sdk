# Agent Observability API URL. See the Grafana Cloud Agent Observability getting started docs:
# https://grafana.com/docs/grafana-cloud/machine-learning/agent-observability/get-started/grafana-cloud/
# Copy the API URL from Observability → Agent Observability → Configuration.
AGENTO11Y_PROTOCOL=http
AGENTO11Y_AUTH_MODE=basic
AGENTO11Y_ENDPOINT=https://agento11y-prod-<region>.grafana.net
AGENTO11Y_CONVERSATION_ID=agento11y-strands-demo

# Numeric instance ID. Used as the basic-auth user and X-Scope-OrgID tenant.
AGENTO11Y_AUTH_TENANT_ID=

# Cloud Access Policy Token (`glc_…`) with `sigil:write` scope (basic-auth password).
AGENTO11Y_AUTH_TOKEN=

# OTel traces and metrics export. Use the URL and OTLP instance ID from Cloud portal -> stack -> OpenTelemetry.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 of OTLP_INSTANCE_ID:AGENTO11Y_AUTH_TOKEN>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRIC_EXPORT_INTERVAL_MILLIS=1000
OTEL_SERVICE_NAME=agento11y-strands-typescript-example

# The example uses Strands' OpenAI model provider.
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
