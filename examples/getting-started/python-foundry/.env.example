# --- Microsoft Foundry ---
# Project endpoint format:
# https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_FOUNDRY_PROJECT_ENDPOINT=
AZURE_FOUNDRY_MODEL=gpt-5.2

# Uses DefaultAzureCredential. For local development, run `az login` first.

# --- Sigil generation export ---
SIGIL_PROTOCOL=http
SIGIL_ENDPOINT=https://sigil-prod-<region>.grafana.net
SIGIL_AUTH_MODE=basic
SIGIL_AUTH_TENANT_ID=
SIGIL_AUTH_TOKEN=

# --- OTel traces + metrics ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://<your-otlp-gateway-url>
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(otlp_instance_id:cloud_api_token)>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRIC_EXPORT_INTERVAL_MILLIS=1000
OTEL_SERVICE_NAME=sigil-foundry-example

SIGIL_CONVERSATION_ID=sigil-foundry-demo
SIGIL_AGENT_VERSION=dev
