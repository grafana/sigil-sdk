<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net8.0</TargetFrameworks>
    <AssemblyName>Grafana.Agento11y.OpenAI</AssemblyName>
    <RootNamespace>Grafana.Agento11y.OpenAI</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);OPENAI001</NoWarn>
    <PackageId>Grafana.Agento11y.OpenAI</PackageId>
    <Description>Grafana Agent Observability OpenAI provider helpers for .NET.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Grafana.Agento11y/Grafana.Agento11y.csproj" />
    <PackageReference Include="OpenAI" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
