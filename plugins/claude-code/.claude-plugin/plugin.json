{
  "name": "sigil-cc",
  "version": "0.4.0",
  "description": "Send Claude Code session telemetry to Grafana Agent Observability",
  "author": {
    "name": "Grafana Labs"
  },
  "repository": "https://github.com/grafana/sigil-sdk",
  "homepage": "https://github.com/grafana/sigil-sdk/tree/main/plugins/claude-code",
  "license": "Apache-2.0",
  "keywords": ["telemetry", "observability", "sigil", "grafana"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agento11y claude-code hook || sigil claude-code hook",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agento11y claude-code hook || sigil claude-code hook",
            "timeout": 2000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agento11y claude-code hook || sigil claude-code hook",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agento11y claude-code hook || sigil claude-code hook",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
